# MHES environment configuration.
#
# Copy this file to ".env" and fill in real values for your environment.
# ".env" is git-ignored — never commit real credentials or bucket names.
# Values here are loaded automatically on startup (see config.py, which
# calls python-dotenv's load_dotenv() before reading any of these).

# ── Google Cloud Storage (export file storage — services/gcs_service.py) ──

# GCP project id. Optional — if omitted, it's inferred from the service
# account credentials below.
GCP_PROJECT_ID=

# Name of the GCS bucket export files are uploaded to (must already exist
# and be private — see docs/ARCHITECTURE.md for bucket/IAM setup).
# Example: GCP_BUCKET_NAME=mhes-export-files
GCP_BUCKET_NAME=

# Absolute path to a service account JSON key file with permission to
# read/write objects in the bucket above. Read directly by the
# google-cloud-storage / google-auth libraries — not by MHES's own config.
# Example: GOOGLE_APPLICATION_CREDENTIALS=D:\Infa\secrets\mhes-gcs-key.json
GOOGLE_APPLICATION_CREDENTIALS=

# ── Flask ──
# SECRET_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# TEMP_DATA_RETENTION_DAYS=7
# TEMP_DATA_CLEANUP_TIMES=10:00,15:00
# TEMP_DATA_TIMEZONE=Asia/Yangon
